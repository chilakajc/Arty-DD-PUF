####################################################################################
# Constraints from file : 'Nx_dd_puf02.xdc'
####################################################################################

## NX LAYOUT CONSTRAINTS 16-BIT PUF 002 -- STREAMLINED NET DELAYS & MID D-LATCH RANGE

## Clock signal
current_instance -quiet
set_property -dict {PACKAGE_PIN E3 IOSTANDARD LVCMOS33} [get_ports clk]
#set_property -dict {PACKAGE_PIN E3 IOSTANDARD LVCMOS33} [get_ports clk_lo]
create_clock -period 1000.000 -name sys_clk_pin -waveform {0.000 500.000} -add [get_ports clk]
